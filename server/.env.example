# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Local MongoDB (mongod running on default port)
MONGO_URI=mongodb://127.0.0.1:27017/skin-treatment

# JWT
JWT_SECRET=replace-with-a-long-random-string-at-least-64-chars
JWT_EXPIRES_IN=7d

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Nodemailer / Gmail SMTP (use App Password, not your real Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Skin Treatment <noreply@skintreatment.local>"

# Admin seed (used by scripts/seed.js)
SEED_ADMIN_EMAIL=admin@skintreatment.local
SEED_ADMIN_PASSWORD=Admin@12345
